generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CLIENT
  WORKER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BLOCKED
}

model User {
  id          Int        @id @default(autoincrement())
  clerkUserId String     @unique
  email       String     @unique
  role        UserRole?
  status      UserStatus @default(ACTIVE)

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}